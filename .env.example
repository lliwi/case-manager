# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=development
FLASK_APP=wsgi.py

# PostgreSQL Database
POSTGRES_DB=case_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://postgres:change-this-password@postgres:5432/case_manager

# Neo4j Graph Database
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password
NEO4J_URI=bolt://neo4j:7687

# Redis & Celery
REDIS_PASSWORD=change-this-password
REDIS_URL=redis://:change-this-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-this-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-this-password@redis:6379/1

# Flower (Celery monitoring) - basic auth is REQUIRED, the container will not
# start without FLOWER_PASSWORD. Flower is bound to 127.0.0.1 on the host.
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-password

# Evidence Encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
EVIDENCE_ENCRYPTION_KEY=change-this-to-a-64-character-hex-string

# API key encryption (third-party API keys stored in DB). Kept separate from
# EVIDENCE_ENCRYPTION_KEY so rotating one does not invalidate the other.
# If unset, the app falls back to EVIDENCE_ENCRYPTION_KEY.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_ENCRYPTION_KEY=change-this-to-a-64-character-hex-string

# Trusted Timestamp Service (optional)
TIMESTAMP_SERVICE_URL=

# Docker Volume Paths (for local development)
HOST_POSTGRES_PATH=./volumes/postgres
HOST_EVIDENCE_PATH=./volumes/evidence
